# PostgreSQL (Aiven)
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=

# PostgreSQL connection pool tuning (optional; sensible defaults applied if unset).
# PG_POOL_MAX: max simultaneous DB connections this process holds. Keep below the
#   provider's per-database limit. When running N backend instances, the limit is
#   shared across all of them (e.g. limit 80, 4 instances → ~18 each).
PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS: close idle pooled clients after this many ms.
PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS: fail fast if no connection is free within this many ms.
PG_CONNECTION_TIMEOUT_MS=10000

# Results dashboard cache TTL in ms (optional; default 5000). Aggregate election
# results are cached per-instance for this long to absorb polling bursts when an
# election closes. A successful vote invalidates the cache immediately. Set to 0
# to disable caching.
RESULT_CACHE_TTL_MS=5000

# PM2 cluster worker count (optional; defaults to 'max' = one per CPU core).
# Lower this to cap total DB connections (instances × PG_POOL_MAX).
PM2_INSTANCES=max

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Hostinger SMTP (Nodemailer)
# Use port 465 with SSL (secure). SMTP_USER/SMTP_FROM must be a Hostinger mailbox
# on your domain. Quote the password if it contains special characters.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Application
SESSION_SECRET=
APP_BASE_URL=
# Frontend origin(s) allowed by CORS. Comma-separate to allow several
# (e.g. https://fa2i.in,https://www.fa2i.in). Must EXACTLY match the browser
# origin (scheme + host), no trailing slash.
FRONTEND_URL=

# Admin bootstrap (email for the first Federation Administrator)
ADMIN_EMAIL=

# Optional public URL to override the federation email logo. If empty, the bundled logo at src/assets/fa2i-logo.jpg is embedded inline.
FEDERATION_LOGO_URL=
